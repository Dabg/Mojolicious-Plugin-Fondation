<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= l 'Forbidden' %></title>
  <style>
    :root {
      --bg: #f8fafd;
      --text: #1e2937;
      --muted: #64748b;
      --accent: #0ea5e9;
      --border: #e2e8f0;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: "JetBrains Mono", "Fira Code", system-ui, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .error-box {
      text-align: center;
      padding: 48px 40px;
      max-width: 480px;
    }
    .error-code {
      font-size: 6rem;
      font-weight: 700;
      letter-spacing: -2px;
      color: #f59e0b;
      line-height: 1;
      margin-bottom: 12px;
    }
    .error-title {
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 16px;
    }
    .error-message {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 32px;
    }
    .home-link {
      display: inline-block;
      padding: 10px 28px;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--accent);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: background 0.15s, border-color 0.15s;
    }
    .home-link:hover {
      background: rgba(14, 165, 233, 0.06);
      border-color: var(--accent);
    }
  </style>
</head>
<body>
  <div class="error-box">
    <div class="error-code">403</div>
    <div class="error-title"><%= l 'Forbidden' %></div>
    <div class="error-message"><%= l 'You do not have permission to access this resource.' %></div>
    <a href="/" class="home-link"><%= l 'Go Home' %></a>
  </div>
</body>
</html>
